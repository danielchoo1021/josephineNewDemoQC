{{-- Categories--}}
<script>
    let hasBeenShown_categories = false;

    function show_categories(element) {
        element.style.opacity = 1;
    }

    function showCategoriesAfterDelay() {
        if (!hasBeenShown_categories) {
            const categoriesDiv = document.getElementById('categories-div-show');
            show_categories(categoriesDiv);
            hasBeenShown_categories = true;
        }
    }

    setTimeout(showCategoriesAfterDelay, 1000);

    function scroll_categories() {
        const scrollPosition = window.scrollY;
        const categoriesDiv = document.getElementById('categories-div-show');

        const elementTopOffset = categoriesDiv.getBoundingClientRect().top;
        const windowHeight = window.innerHeight;

        if (elementTopOffset <= windowHeight && !hasBeenShown_categories) {
            setTimeout(function() {
                show_categories(categoriesDiv);
                hasBeenShown_categories = true;
            }, 1000);
        }
    }

    window.addEventListener("scroll", scroll_categories);
    window.addEventListener("touchmove", scroll_categories);
</script>


