   .award-card__background {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: -1;
        transition: 0.5s ease-out;
        transform-origin: bottom right; 
    }

    .award-card__background img {
        height: 100%;
        width: 100%;
        padding-left: 20px;
        padding-right: 20px;
        object-fit: contain;
    }

    .category-one .award-card__content {
