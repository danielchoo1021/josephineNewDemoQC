<style type="text/css">
    .slick-prev:before {
        text-decoration: none;
        transition: all 500ms 100ms; 
        opacity: 0.3;
        color:#0000003d;
        content: '\f104'; 
        font-family: "Font Awesome 5 Pro"; 
        font-weight: 900;
        font-size: 90px;
        position: absolute;
        top: 31%;
        transform: translate(0%, -50%);
        left: 2px;
        display: none;
    }

    .slick-next:before {
        text-decoration: none;
        transition: all 500ms 100ms; 
        opacity: 0.3;
        color:#0000003d;
        content: '\f105'; 
        font-family: "Font Awesome 5 Pro"; 
        font-weight: 900;
        font-size: 90px;
        position: absolute;
        top: 31%;
        transform: translate(50%, -50%);
        right: 0px;
        display: none;
    }

    .slick-prev:hover:not(.slick-disabled), .slick-next:hover:not(.slick-disabled) {
        text-decoration: none;
    }

    .slick-prev:hover:not(.slick-disabled):before, .slick-next:hover:not(.slick-disabled):before {
        color: #00000042;
    }

    .countdown {
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: center;
    }

    .countdown-item {
        display: flex;
        flex-direction: column;
        text-align: center;
        margin-right: 10px;
        padding: 20px;
        background: linear-gradient(to right, #022D24, #046854);
        box-shadow: 0 1px 3px #022D24;
    }

    .countdown-value {
        font-size: 20px;
        color: #e5f5eb;
        font-weight: 600;
        border-bottom: 1px solid #1b4c43;
    }

    .countdown-label {
        color: #b0bbb4;
        font-weight: 700;
        font-family: system-ui;
        font-size: 16px;
        text-transform: uppercase;
    }

    .hs-product-name {
        text-decoration: none;
        line-height: 1.625em;
        transition: 0.2s ease-in-out;
        display: block;
        margin-bottom: 0.625em;
        overflow: hidden;
        text-overflow: ellipsis;
        display: -webkit-box;
        -webkit-line-clamp: 1;
        font-size: 27px;
        font-family: 'Montserrat', sans-serif;
        font-weight: 700;
        color: #000000;
        cursor: text;
        -webkit-box-orient: vertical;
    }

    @media (max-width: 992px) {
        .fs-container {
            margin-bottom: 0px;
        }
    }

    @media (max-width: 576px) {
        .countdown-item {
            margin-right: 5px;
        }

        .countdown-value {
            font-size: 13px;
        }

        .countdown-label {
            font-size: 5px;
        }
    }

    @media (max-width: 540px) {
        .hs-product-name {
            font-size: 12px;
        }
    }

    @media (max-width: 430px) {
        .fs-margin {
            margin-bottom: 0px;
        }

        .countdown-item {
            padding: 10px;
        }

        .countdown-value {
            font-size: 8px;
        }

        .countdown-label {
            font-size: 3px;
        }
    }

    .owl-nav {
        text-align: inherit !important;
        max-width: 100%;
        margin-top: 0 !important;
    }

    .promotions__item {
        height: 270px;
        position: relative;
    }

    .promotions__item h5 {
        position: absolute;
        left: 0;
        width: 100%;
        padding: 0 20px;
        bottom: 20px;
        text-align: center;
    }

    .promotions__item h5 a {
        font-size: 18px;
        color: #1c1c1c;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        padding: 12px 0 10px;
        background: #ffffff;
        display: block;
    }

    .owl-nav button {
        border: none !important;
        background-color: transparent !important;
    }

    @media only screen and (max-width: 767px){
        .owl-prev {
            left: -10px !important;
        }
    }

    .fs-featured-item {
        position: relative;
        margin-top: 20px;
        border-radius: 10px;
        transition: transform 0.2s ease-in-out;
        box-shadow: 0px 6px 10px -6px #022D24;
        z-index: 1;
    }

    .fs-featured-item:hover {
        background-color: #fff;
        transform: scale(1.03);
        z-index: 9999;
    }

    .fs-featured-item::after {
        position: absolute;
        content: "";
        bottom: 0;
        left: 0;
        width: 100%;
        height: 0; 
        background: linear-gradient(to top, #022D24, #046854);
        border-radius: 50px 50px 0 0;
        transition: height 0.3s ease-in-out; 
    }

    .fs-featured-item:hover::after {
        height: 10px;
    }

    .featured.spad {
        padding-top: 0 !important;
        padding-bottom: 0 !important;
    }

    .categories__slider.owl-carousel .owl-nav button {
        height: auto !important;
    }

    .birthday_popup .modal-body img {
        height: auto !important;
    }

    .container-slider {
        position: relative;
        width: 100%;
        max-width: none !important;
        padding: 0;
        margin: 0;
        overflow: hidden;
        height: 0;
        animation: CSFadeIn 2s forwards;
    }

    @keyframes CSFadeIn {
        0% {
            height: 0;
        }
        100% {
            height: 100%;
        }
    }

    .container-slider.show {
        animation: none;
        height: auto;
    }

    .sdr-slide1, .sdr-slide2, .sdr-slide {
        position: absolute;
        width: 100%;
    }

    .sdr-slide1 {
        height: 100%; 
        text-align: center;
        animation-name: slideInFromTop;
        animation-duration: 2s;
        animation-timing-function: ease-out;
        animation-fill-mode: forwards;
        background-color: rgba(10, 10, 10, 0.133);
    }

    .sdr-slide2 {
        height: 100%; 
        text-align: center;
        animation-name: slideInFromBottom;
        animation-duration: 2s;
        animation-timing-function: ease-out;
        animation-fill-mode: forwards;
        background-color: rgba(115, 112, 112, 0.138);
    }

    .sdr-slide {
        animation-name: slideInFromBottom;
        animation-duration: 2.5s;
        animation-timing-function: ease-out;
        animation-fill-mode: forwards;
    }

    @keyframes slideInFromTop {
        from {
            transform: translateY(-100%);
            opacity: 0;
        }
        to {
            transform: translateY(0);
            opacity: 0.2;
        }
    }

    @keyframes slideInFromBottom {
        from {
            transform: translateY(100%);
            opacity: 0;
        }
        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    .btn-view-category {
        font-family: system-ui;
        position: relative;
        width: 100%; 
        height: 100%;
        border: 0px;
        background-color: transparent;
        color: #7a0303;
        font-size: 18px;
        transition: background-color 0.7s ease-in-out, color 0.3s ease-in-out, transform 0.7s ease-in-out, opacity 0.7s ease-in-out;
        /* border-radius: 15px; */
        overflow: hidden;
        text-align: center;
        transform: scale(1);
        backface-visibility: hidden;
        will-change: transform; 
    }

    .btn-view-category::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 0;
        height: 100%;
        background: linear-gradient(230deg, #0000001a, #00000052);
        transition: width 0.4s ease-in-out;
    }

    .btn-view-category:hover {
        color: #fff;
        opacity: 1;
        padding: 2px;
        --p: 10%;
        /* --t: 1s;
        --m: 10%; */
        background: linear-gradient(to right, #0000004d, #fefefe) 0/var(--p) 100% no-repeat, 
                    linear-gradient(to left, #0000004d, #fefefe) 100% 50%/var(--p) 100% no-repeat, 
                    linear-gradient(to right, #0000004d, #0000003d) 100% 0%/var(--p) 30px no-repeat, 
                    linear-gradient(to right, #00000038, #0000003d) 0% 100%/var(--p) 30px no-repeat;
        /* background-color: transparent; */
        /* padding: 30px 30px 30px 30px; */
    }

    .btn-view-category:hover::before {
        width: 100%;
    }

    .btn-view-category span {
        position: relative;
        z-index: 1;
        transform: translateZ(0);
    }

    .btn-view-category::after {
        /* content: "\2192"; */
        position: absolute;
        transform: translate(-50%, -50%) scale(1);
        top: 50%;
        left: 50%;
        opacity: 0;
        transition: opacity 0.7s ease-in-out, transform 0.7s ease-in-out;
    }

    .btn-view-category:hover::after {
        opacity: 1;
        transform: translate(-50%, -50%) scale(6);
    }

    .btn-view-category:hover .categories-learn-more {
        color: #fff;
        transition: 0.5s ease-in-out;
    }

    .flash-sales-title { 
        font-family: system-ui;
        color: #000000; 
        font-size: 50px; 
        letter-spacing: 1.5px;
        font-weight: 700;
    }

