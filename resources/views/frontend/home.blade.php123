    .introduction-seven__wrapper.-bottom {
        position: relative;
        display: inline-block;
        /* padding: 20px; */
        background-color: #ccc;
        transition: transform 0.3s;
    }

    .introduction-seven__wrapper.-bottom::before {
        content: "";
        top: 0;
        width: 60%;
        height: 100%;
        z-index: -9999;
        opacity: 0.5;
    }

    .introduction-seven__wrapper.-bottom img {
        transition: all 0.3s ease;
    }

    .introduction-seven-wrapper-image-fm {
        max-width: 45.5%; 
    }

    .introduction-seven-wrapper-image-fm img {
        height: 400px;
        width: 100%;
        object-fit: cover; 
    }

    .introduction-seven-wrapper-content-detail-fm h5 {
        color: #383838;
        font-size: 0.9375em;
        font-weight: normal;
        line-height: 1;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        margin-bottom: 2em; 
    }
    .introduction-seven-wrapper-content-detail-fm h3 {
        color: #383838;
        font-size: 3.75em;
        font-weight: 600;
        line-height: 1;
        margin-bottom: 0.66667em; 
    }
    .introduction-seven-wrapper-content-detail-fm p {
        color: #111;
        font-size: 0.875em;
        font-weight: normal;
        line-height: 1.71429em;
        margin-bottom: 2.85714em; 
    }
    .introduction-seven-wrapper-content-detail-fm {
        /* padding-left: 3.25em;     */
    }

    .introduction-seven__wrapper-description {
        /* color: #7a0303; */
        font-size: 19px;
        font-weight: 500;
        letter-spacing: 0.4px;
    }

    .welcome-main-margin {
        width: 100%;
        padding-right: 15px;
        padding-left: 15px;
        margin-right: auto;
        margin-left: auto;
        max-width: 1500px; 
        margin-top: 200px;
        margin-bottom: 80px;
    }

    .welcome-margin {
        margin-top: 70px;
    }

    .welcome-title {
        font-family: sans-serif;
        margin-bottom: 10px;
        /* color: #4c4c4c; */
        color: #7a0303;
        font-size: 40px;
        line-height: 1.5;
        font-weight: 800;
    }

    .welcome-border-red {
        height: 3px;
        width: 20%;
        margin: 35px 0 40px 0;
        /* background-color: #a01718; */
        background-color: #7a0303;
        z-index: 9999;
    }

    @keyframes slideFromLeft {
        0% {
            transform: translateX(-100%); 
            opacity: 0; 
        }
        100% {
            transform: translateX(0%); 
            opacity: 1; 
        }
    }

    .slide-from-left {
        animation: slideFromLeft 3s ease-out; 
    }

