<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Serve real files/directories at the project root directly (e.g. robots.txt)
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # Serve static assets that only exist under public/ (frontend/, css/, js/,
    # uploads/, etc.) directly from there, without invoking PHP.
    # Case 1: app served from a URL subfolder (e.g. local XAMPP at
    # /josephineNewDemoQC/...) — strip the subfolder before checking public/.
    RewriteCond %{REQUEST_URI} ^/josephineNewDemoQC/(.+)$
    RewriteCond %{DOCUMENT_ROOT}/josephineNewDemoQC/public/%1 -f
    RewriteRule ^(.+)$ public/%1 [L]

    # Case 2: app served from a domain root (e.g. production hosting), where
    # DOCUMENT_ROOT already points at this project's root.
    RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -f
    RewriteRule ^(.+)$ public/$1 [L]

    # Everything else (actual Laravel routes) goes through the root front
    # controller, so SCRIPT_NAME/REQUEST_URI stay consistent for routing.
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>
<IfModule mod_headers.c>
  <FilesMatch "\.(ttf|ttc|otf|eot|woff|woff2|font.css)$">
    Header set Access-Control-Allow-Origin "*"
  </FilesMatch>
</IfModule>

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php81” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php81 .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
